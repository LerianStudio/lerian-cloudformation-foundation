templates:
  - templates/*.yaml

regions:
  - us-east-1
  - us-east-2
  - us-west-1
  - us-west-2
  - eu-west-1
  - eu-west-2
  - eu-central-1
  - ap-southeast-1
  - ap-southeast-2
  - ap-northeast-1
  - sa-east-1

ignore_checks:
  # Allow longer Lambda inline code for Marketplace deployment simplicity
  - W3002
  # Allow hardcoded availability zones in templates
  - W3010

configure_rules:
  # Ensure all parameters have descriptions
  E3012:
    strict: true
